# Runtime
NODE_ENV=development
PORT=3000

# Database
# Use mysql in production. Use sqlite only for local development.
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kuwanyubeiqi
DB_USER=kuwan_user
DB_PASSWORD=replace-with-secure-password

# JWT
# Required in production. Do not use default_secret/default_refresh_secret.
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Product image storage
# Leave OSS_* empty to use local uploads in development.
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
