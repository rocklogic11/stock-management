# ============================================
# 酷玩预备齐库存管理系统 - 生产环境配置模板
# 复制此文件为 .env.production 并修改相应配置
# ============================================

# 环境标识
NODE_ENV=production

# 服务端口
PORT=3000

# 数据库配置（生产环境推荐使用MySQL）
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kuwanyubeiqi_prod
DB_USER=root
DB_PASSWORD=change_this_to_secure_password

# JWT配置（生产环境必须修改！！！）
# 使用以下命令生成安全密钥：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_random_32_char_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change_this_to_another_random_32_char_string
JWT_REFRESH_EXPIRES_IN=7d

# Redis配置（可选，用于缓存加速）
# 如果不使用Redis，留空或注释掉
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# CORS配置（生产环境必须指定域名，多个域名用逗号分隔）
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
