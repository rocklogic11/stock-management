# ============================================
# Docker 部署环境变量模板
# 复制此文件为 .env.docker 并修改
# ============================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_USER=kuwanyubeiqi
MYSQL_PASSWORD=your_secure_user_password_here

# JWT 配置 (使用node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成)
JWT_SECRET=your_32_char_hex_string_here
JWT_REFRESH_SECRET=your_another_32_char_hex_string_here

# 端口配置 (可选，默认已配置)
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# BACKEND_PORT=3000
# MYSQL_PORT=3306
# REDIS_PORT=6379
